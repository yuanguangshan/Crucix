// Series definitions with their v2 API paths
const OIL_SERIES = {
  wti: {
    label: 'WTI Crude Oil ($/bbl)',
    path: '/petroleum/pri/spt/data/',
    params: { frequency: 'daily', 'data[0]': 'value', facets: { series: ['RWTC'] } },
  },
