        'Content-Type': 'application/x-www-form-urlencoded',
        'User-Agent': 'Crucix/1.0 intelligence-engine',
      },
      body: 'grant_type=client_credentials',
    });
    if (!res.ok) return null;
    const data = await res.json();
    return data.access_token || null;
  } catch {
    return null;
  }
}

